{
  "name": "@taiyme/eslint-config",
  "version": "1.0.1",
  "private": false,
  "description": "taiyのためのESLint共有設定",
  "homepage": "https://github.com/taiyme/eslint-config",
  "bugs": "https://github.com/taiyme/eslint-config/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/taiyme/eslint-config.git"
  },
  "license": "MIT",
  "author": "taiy <me@taiy.me> (https://taiy.me/)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/typegen.ts && tsdown",
    "clean": "node ./scripts/clean.ts && pnpm store prune",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "4.2.1",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-perfectionist": "5.8.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "typescript-eslint": "8.58.0"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@typescript-eslint/parser": "8.59.1",
    "better-typescript-lib": "2.12.0",
    "eslint": "10.2.1",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-typegen": "2.3.1",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "tsdown": "0.21.7",
    "type-fest": "5.6.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0",
    "typescript": ">=5.5.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": false
    },
    "typescript": {
      "optional": false
    }
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.28.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
